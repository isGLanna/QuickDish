{
  "expo": {
    "name": "QuickDish",
    "slug": "QuickDish",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "quickdish",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "${MAPS_API_KEY}"
      }
    },
    "android": {
      "name": "QuickDish",
      "slug": "quickdish",
      "package": "com.quickdish.app",
      "adaptiveIcon": {
        "backgroundColor": "#C9A15B",
        "foregroundImage": "./src/assets/images/android-icon-foreground.png",
        "backgroundImage": "./src/assets/images/android-icon-background.png",
        "monochromeImage": "./src/assets/images/android-icon-monochrome.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "${MAPS_API_KEY}"
        }
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow QuickDish to access your photos to upload a profile picture.",
          "cameraPermission": "Allow QuickDish to access your camera to take a profile picture.",
          "colors": {
            "cropToolbarColor": "#C9A15B"
          },
          "dark": {
            "cropToolbarColor": "#C9A15B"
          }
        }
      ],
      "@rnmapbox/maps",
      "expo-location",
      {
        "locationWhenInUsePermission": "Allow QuickDish to access your location when the app is in use."
      }
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
